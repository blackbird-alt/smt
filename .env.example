VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Set to "false" to disable the AI "Ask for help" assistant (the app and all
# hand-written hints/feedback keep working without it). Defaults to enabled.
VITE_AI_ENABLED=

# URL of the Cloudflare Worker that proxies OpenAI (see /worker). The "Ask for
# help" feature only appears when this is set. The OpenAI key lives in the
# Worker, never here. e.g. https://brillyant-ai-proxy.<subdomain>.workers.dev
VITE_AI_PROXY_URL=
