rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Private per-user data: only the owner can read or write it.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /progress/{lessonId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // A learner's own friends list (one-way "added" relationships).
      match /friends/{friendId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // World-readable public stats used by leaderboards and friend search.
    // Anyone signed in can read; only the owner can write — and writes are
    // shape-validated so the public collection can't be injected with arbitrary
    // fields, wrong types, or oversized strings (resource-abuse hardening).
    match /publicProfiles/{userId} {
      function validPublicProfile() {
        let d = request.resource.data;
        return d.keys().hasOnly(['username', 'displayName', 'avatarId', 'xp', 'streak', 'updatedAt'])
          && d.username is string && d.username.size() <= 40
          && d.displayName is string && d.displayName.size() <= 80
          && (!('avatarId' in d) || d.avatarId == null
              || (d.avatarId is string && d.avatarId.size() <= 40))
          && d.xp is number && d.xp >= 0
          && d.streak is number && d.streak >= 0
          && (!('updatedAt' in d) || d.updatedAt is timestamp);
      }

      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && validPublicProfile();
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
