rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /progress/{lessonId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // A learner's own friends list (one-way "added" relationships).
      match /friends/{friendId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // World-readable public stats used by leaderboards and friend search.
    // Anyone signed in can read; only the owner can write their own entry.
    match /publicProfiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
